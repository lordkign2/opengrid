# Generated by cargo
# will have compiled files and executables
target/

# Remove Cargo.lock from gitignore if you depend on a published version of the crate
!Cargo.lock

# For building documentation
/doc

# For building with cross
.cross/

# Runtime artifacts
dist/
build/
*.dSYM/

# IDE specific files
.vscode/
.vs/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
/tmp/

# Log files
*.log
logs/

# Editor backup files
*.bak
*.orig
*.rej

# Coverage reports
coverage/
*.lcov

# Configuration files that might contain secrets
config/
*.env
.env.local
.env.production

# Test artifacts
.mypy_cache/
.pytest_cache/
__pycache__/

# Docker
.dockerignore

# Network simulation or testing artifacts
*.pcap
*.cap
netns/

